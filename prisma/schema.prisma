generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactSubmission {
  id                    String                        @id @default(uuid()) @db.Uuid
  name                  String
  email                 String
  message               String
  fingerprint           String
  ipHash                String?
  userAgent             String?
  reviewStatus          ContactSubmissionReviewStatus @default(NEW)
  deliveryStatus        ContactDeliveryStatus         @default(PENDING)
  deliveryAttempts      Int                           @default(0)
  lastDeliveryAttemptAt DateTime?
  deliveredAt           DateTime?
  lastDeliveryError     String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  @@index([createdAt])
  @@index([reviewStatus, createdAt])
  @@index([deliveryStatus, createdAt])
  @@index([email, createdAt])
  @@index([ipHash, createdAt])
  @@index([fingerprint, createdAt])
}

enum ContactSubmissionReviewStatus {
  NEW
  IN_REVIEW
  RESOLVED
  SPAM
}

enum ContactDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}
